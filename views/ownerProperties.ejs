<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>RentEase – My Properties</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Segoe UI', sans-serif; background: #f0f4ff; }
    nav { background: #1e1b4b; padding: 14px 32px; display: flex; justify-content: space-between; align-items: center; }
    nav .brand { color: #fff; font-size: 20px; font-weight: 800; text-decoration: none; }
    nav .links a { color: rgba(255,255,255,0.8); text-decoration: none; margin-left: 20px; font-size: 14px; font-weight: 500; }
    nav .links a:hover { color: #fff; }
    .container { max-width: 1100px; margin: 0 auto; padding: 36px 24px; }
    .header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 28px; }
    .header h2 { font-size: 24px; color: #1f2937; font-weight: 700; }
    .btn-add { padding: 10px 22px; background: #1e1b4b; color: #fff; border: none; border-radius: 8px; font-size: 14px; font-weight: 600; text-decoration: none; cursor: pointer; }
    .btn-add:hover { background: #312e81; }
    .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 22px; }
    .card { background: #fff; border-radius: 14px; overflow: hidden; box-shadow: 0 2px 12px rgba(0,0,0,0.07); }
    .card-img { background: linear-gradient(135deg, #4338ca, #1e1b4b); height: 120px; display: flex; align-items: center; justify-content: center; font-size: 52px; }
    .card-body { padding: 20px; }
    .card-type { font-size: 11px; font-weight: 700; text-transform: uppercase; color: #4f46e5; background: #eef2ff; padding: 3px 10px; border-radius: 20px; display: inline-block; margin-bottom: 8px; }
    .card-name { font-size: 16px; font-weight: 700; color: #1f2937; margin-bottom: 4px; }
    .card-location { font-size: 13px; color: #6b7280; margin-bottom: 10px; }
    .card-meta { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 14px; }
    .meta-pill { font-size: 11px; color: #374151; background: #f3f4f6; border-radius: 20px; padding: 3px 9px; }
    .card-price { font-size: 17px; font-weight: 800; color: #1e1b4b; margin-bottom: 16px; }
    .card-price span { font-size: 12px; color: #6b7280; font-weight: 400; }
    .card-actions { display: flex; gap: 10px; }
    .btn-edit { flex: 1; padding: 8px; background: #eef2ff; color: #4f46e5; border: none; border-radius: 8px; font-size: 13px; font-weight: 600; text-decoration: none; text-align: center; cursor: pointer; }
    .btn-edit:hover { background: #e0e7ff; }
    .btn-delete { flex: 1; padding: 8px; background: #fef2f2; color: #b91c1c; border: none; border-radius: 8px; font-size: 13px; font-weight: 600; cursor: pointer; }
    .btn-delete:hover { background: #fee2e2; }
    .empty { text-align: center; padding: 70px 20px; color: #6b7280; }
    .empty .icon { font-size: 56px; margin-bottom: 16px; }
    .empty a { color: #4f46e5; font-weight: 600; text-decoration: none; }
  </style>
</head>
<body>
  <nav>
    <a class="brand" href="/owner/dashboard">🏠 RentEase <span style="font-size:12px;opacity:0.7;margin-left:4px;">Owner</span></a>
    <div class="links">
      <a href="/owner/properties">Properties</a>
      <a href="/owner/bookings">Bookings</a>
      <a href="/owner/add-property">+ Add</a>
      <a href="/owner/profile">Profile</a>
      <a href="/logout">Logout</a>
    </div>
  </nav>
  <div class="container">
    <div class="header">
      <h2>🏠 My Properties (<%= properties.length %>)</h2>
      <a class="btn-add" href="/owner/add-property">+ Add Property</a>
    </div>
    <% if (properties.length === 0) { %>
      <div class="empty">
        <div class="icon">🏘️</div>
        <p>You haven't listed any properties yet.</p>
        <p style="margin-top:12px"><a href="/owner/add-property">Add your first property →</a></p>
      </div>
    <% } else { %>
      <div class="grid">
        <% properties.forEach(p => { %>
          <div class="card">
            <div class="card-img">
              <% if (p.type === 'villa') { %>🏰
              <% } else if (p.type === 'apartment') { %>🏢
              <% } else if (p.type === 'studio') { %>🛋️
              <% } else if (p.type === 'condo') { %>🏙️
              <% } else { %>🏡<% } %>
            </div>
            <div class="card-body">
              <span class="card-type"><%= p.type %></span>
              <div class="card-name"><%= p.name %></div>
              <div class="card-location">📍 <%= p.location %></div>
              <div class="card-meta">
                <span class="meta-pill">🛏️ <%= p.rooms || 1 %> Room<%= (p.rooms||1)>1?'s':'' %></span>
                <span class="meta-pill">🚿 <%= p.toilets || 1 %> Toilet<%= (p.toilets||1)>1?'s':'' %></span>
                <% if (p.pools > 0) { %><span class="meta-pill">🏊 <%= p.pools %> Pool<%= p.pools>1?'s':'' %></span><% } %>
                <% if (p.parking > 0) { %><span class="meta-pill">🚗 <%= p.parking %> Parking</span><% } %>
              </div>
              <div class="card-price">₹<%= Number(p.price).toLocaleString('en-IN') %> <span>/night</span></div>
              <div class="card-actions">
                <a class="btn-edit" href="/owner/edit-property/<%= p.id %>">✏️ Edit</a>
                <form method="POST" action="/owner/delete-property/<%= p.id %>" onsubmit="return confirm('Delete this property?')">
                  <button class="btn-delete" style="width:100%">🗑️ Delete</button>
                </form>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
</body>
</html>
