<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>RentEase – <%= property.name %></title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Segoe UI', sans-serif; background: #f0f4ff; }
    nav { background: #4f46e5; padding: 14px 32px; display: flex; justify-content: space-between; align-items: center; }
    nav .brand { color: #fff; font-size: 20px; font-weight: 800; text-decoration: none; }
    nav .links a { color: rgba(255,255,255,0.85); text-decoration: none; margin-left: 20px; font-size: 14px; font-weight: 500; }
    nav .links a:hover { color: #fff; }
    .container { max-width: 900px; margin: 0 auto; padding: 36px 24px; }
    .back { display: inline-flex; align-items: center; gap: 6px; color: #4f46e5; text-decoration: none; font-size: 14px; font-weight: 600; margin-bottom: 24px; }
    .back:hover { text-decoration: underline; }
    .hero { background: linear-gradient(135deg, #818cf8, #4f46e5); border-radius: 16px; height: 220px; display: flex; align-items: center; justify-content: center; font-size: 90px; margin-bottom: 28px; }
    .layout { display: grid; grid-template-columns: 1fr 340px; gap: 28px; }
    .detail-card { background: #fff; border-radius: 16px; padding: 28px; box-shadow: 0 2px 12px rgba(0,0,0,0.07); }
    .type-badge { font-size: 11px; font-weight: 700; text-transform: uppercase; color: #4f46e5; background: #eef2ff; padding: 4px 12px; border-radius: 20px; display: inline-block; margin-bottom: 12px; }
    .prop-name { font-size: 26px; font-weight: 800; color: #1f2937; margin-bottom: 6px; }
    .location { font-size: 15px; color: #6b7280; margin-bottom: 22px; }
    .amenities { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-bottom: 24px; }
    .amenity { display: flex; align-items: center; gap: 10px; background: #f9fafb; border-radius: 10px; padding: 12px 16px; }
    .amenity .icon { font-size: 22px; }
    .amenity .info .label { font-size: 11px; color: #6b7280; text-transform: uppercase; font-weight: 600; }
    .amenity .info .value { font-size: 16px; font-weight: 700; color: #1f2937; }
    .price-big { font-size: 30px; font-weight: 800; color: #4f46e5; }
    .price-big span { font-size: 14px; color: #6b7280; font-weight: 400; }
    .booking-card { background: #fff; border-radius: 16px; padding: 28px; box-shadow: 0 2px 12px rgba(0,0,0,0.07); position: sticky; top: 24px; }
    .booking-card h3 { font-size: 18px; font-weight: 700; color: #1f2937; margin-bottom: 20px; }
    .form-group { margin-bottom: 16px; }
    .form-group label { display: block; font-size: 13px; font-weight: 600; color: #374151; margin-bottom: 6px; }
    .form-group input { width: 100%; padding: 10px 14px; border: 1.5px solid #d1d5db; border-radius: 8px; font-size: 14px; outline: none; }
    .form-group input:focus { border-color: #4f46e5; }
    .btn-book { width: 100%; padding: 13px; background: #4f46e5; color: #fff; border: none; border-radius: 10px; font-size: 15px; font-weight: 700; cursor: pointer; }
    .btn-book:hover { background: #4338ca; }
    .alert { padding: 12px 16px; border-radius: 8px; margin-bottom: 16px; font-size: 13px; }
    .alert.error { background: #fef2f2; border: 1px solid #fca5a5; color: #b91c1c; }
    .alert.success { background: #f0fdf4; border: 1px solid #86efac; color: #166534; }
  </style>
</head>
<body>
  <nav>
    <a class="brand" href="/customer/dashboard">🏠 RentEase</a>
    <div class="links">
      <a href="/customer/search">Search</a>
      <a href="/customer/bookings">My Bookings</a>
      <a href="/customer/profile">Profile</a>
      <a href="/logout">Logout</a>
    </div>
  </nav>
  <div class="container">
    <a class="back" href="/customer/search">← Back to Search</a>
    <div class="hero">
      <% if (property.type === 'villa') { %>🏰
      <% } else if (property.type === 'apartment') { %>🏢
      <% } else if (property.type === 'studio') { %>🛋️
      <% } else if (property.type === 'condo') { %>🏙️
      <% } else { %>🏡<% } %>
    </div>
    <div class="layout">
      <div>
        <div class="detail-card">
          <span class="type-badge"><%= property.type %></span>
          <div class="prop-name"><%= property.name %></div>
          <div class="location">📍 <%= property.location %></div>
          <div class="amenities">
            <div class="amenity">
              <span class="icon">🛏️</span>
              <div class="info">
                <div class="label">Rooms</div>
                <div class="value"><%= property.rooms || 1 %></div>
              </div>
            </div>
            <div class="amenity">
              <span class="icon">🚿</span>
              <div class="info">
                <div class="label">Toilets</div>
                <div class="value"><%= property.toilets || 1 %></div>
              </div>
            </div>
            <div class="amenity">
              <span class="icon">🏊</span>
              <div class="info">
                <div class="label">Pools</div>
                <div class="value"><%= property.pools || 0 %></div>
              </div>
            </div>
            <div class="amenity">
              <span class="icon">🚗</span>
              <div class="info">
                <div class="label">Parking Spots</div>
                <div class="value"><%= property.parking || 0 %></div>
              </div>
            </div>
          </div>
          <div class="price-big">₹<%= Number(property.price).toLocaleString('en-IN') %> <span>/night</span></div>
        </div>
      </div>
      <div>
        <div class="booking-card">
          <h3>📅 Book this Property</h3>
          <% if (error) { %><div class="alert error"><%= error %></div><% } %>
          <% if (success) { %><div class="alert success"><%= success %></div><% } %>
          <form method="POST" action="/customer/property/<%= property.id %>/book">
            <div class="form-group">
              <label>Check-in Date</label>
              <input type="date" name="checkin" required min="<%= new Date().toISOString().split('T')[0] %>" />
            </div>
            <div class="form-group">
              <label>Check-out Date</label>
              <input type="date" name="checkout" required min="<%= new Date().toISOString().split('T')[0] %>" />
            </div>
            <button class="btn-book" type="submit">Confirm Booking</button>
          </form>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
