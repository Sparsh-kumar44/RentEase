<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>RentEase – My Bookings</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Segoe UI', sans-serif; background: #f0f4ff; }
    nav { background: #4f46e5; padding: 14px 32px; display: flex; justify-content: space-between; align-items: center; }
    nav .brand { color: #fff; font-size: 20px; font-weight: 800; text-decoration: none; }
    nav .links a { color: rgba(255,255,255,0.85); text-decoration: none; margin-left: 20px; font-size: 14px; font-weight: 500; }
    nav .links a:hover { color: #fff; }
    .container { max-width: 900px; margin: 0 auto; padding: 36px 24px; }
    h2 { font-size: 24px; color: #1f2937; margin-bottom: 6px; font-weight: 700; }
    .subtitle { color: #6b7280; font-size: 14px; margin-bottom: 32px; }
    .section-title { font-size: 17px; font-weight: 700; color: #374151; margin-bottom: 16px; display: flex; align-items: center; gap: 8px; }
    .booking-card { background: #fff; border-radius: 14px; padding: 22px 24px; box-shadow: 0 2px 12px rgba(0,0,0,0.07); margin-bottom: 14px; display: grid; grid-template-columns: 1fr auto; align-items: center; gap: 16px; }
    .b-name { font-size: 17px; font-weight: 700; color: #1f2937; margin-bottom: 4px; }
    .b-location { font-size: 13px; color: #6b7280; margin-bottom: 8px; }
    .b-dates { font-size: 13px; color: #374151; }
    .b-dates span { font-weight: 600; }
    .badge { display: inline-block; font-size: 11px; font-weight: 700; padding: 3px 10px; border-radius: 20px; text-transform: uppercase; }
    .badge.upcoming { background: #eff6ff; color: #1d4ed8; }
    .badge.past { background: #f3f4f6; color: #6b7280; }
    .btn-cancel { padding: 7px 14px; background: #fef2f2; color: #b91c1c; border: 1px solid #fca5a5; border-radius: 8px; font-size: 12px; font-weight: 600; cursor: pointer; }
    .btn-cancel:hover { background: #fee2e2; }
    .empty { text-align: center; padding: 40px; color: #9ca3af; font-size: 14px; }
    .section { margin-bottom: 36px; }
  </style>
</head>
<body>
  <nav>
    <a class="brand" href="/customer/dashboard">🏠 RentEase</a>
    <div class="links">
      <a href="/customer/search">Search</a>
      <a href="/customer/bookings">My Bookings</a>
      <a href="/customer/profile">Profile</a>
      <a href="/logout">Logout</a>
    </div>
  </nav>
  <div class="container">
    <h2>🗂️ My Bookings</h2>
    <p class="subtitle">Manage all your upcoming and past stays.</p>

    <div class="section">
      <div class="section-title">📅 Upcoming (<%= upcoming.length %>)</div>
      <% if (upcoming.length === 0) { %>
        <div class="empty">No upcoming bookings. <a href="/customer/search" style="color:#4f46e5">Find a property →</a></div>
      <% } else { %>
        <% upcoming.forEach(b => { %>
          <div class="booking-card">
            <div>
              <div class="b-name"><%= b.property_name || 'Property #' + b.property_id %></div>
              <div class="b-location">📍 <%= b.location || '' %></div>
              <div class="b-dates">Check-in: <span><%= new Date(b.checkin).toLocaleDateString('en-IN', {day:'numeric', month:'short', year:'numeric'}) %></span> &nbsp;→&nbsp; Check-out: <span><%= new Date(b.checkout).toLocaleDateString('en-IN', {day:'numeric', month:'short', year:'numeric'}) %></span></div>
            </div>
            <div style="display:flex;flex-direction:column;align-items:flex-end;gap:10px;">
              <span class="badge upcoming">Upcoming</span>
              <form method="POST" action="/customer/bookings/<%= b.id %>/cancel" onsubmit="return confirm('Cancel this booking?')">
                <button class="btn-cancel">Cancel</button>
              </form>
            </div>
          </div>
        <% }) %>
      <% } %>
    </div>

    <div class="section">
      <div class="section-title">✅ Past Stays (<%= past.length %>)</div>
      <% if (past.length === 0) { %>
        <div class="empty">No past stays yet.</div>
      <% } else { %>
        <% past.forEach(b => { %>
          <div class="booking-card">
            <div>
              <div class="b-name"><%= b.property_name || 'Property #' + b.property_id %></div>
              <div class="b-location">📍 <%= b.location || '' %></div>
              <div class="b-dates">Check-in: <span><%= new Date(b.checkin).toLocaleDateString('en-IN', {day:'numeric', month:'short', year:'numeric'}) %></span> &nbsp;→&nbsp; Check-out: <span><%= new Date(b.checkout).toLocaleDateString('en-IN', {day:'numeric', month:'short', year:'numeric'}) %></span></div>
            </div>
            <span class="badge past">Completed</span>
          </div>
        <% }) %>
      <% } %>
    </div>
  </div>
</body>
</html>
