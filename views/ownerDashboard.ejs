<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>RentEase – Owner Dashboard</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Segoe UI', sans-serif; background: #f0f4ff; }
    nav { background: #1e1b4b; padding: 14px 32px; display: flex; justify-content: space-between; align-items: center; }
    nav .brand { color: #fff; font-size: 20px; font-weight: 800; text-decoration: none; }
    nav .links a { color: rgba(255,255,255,0.8); text-decoration: none; margin-left: 20px; font-size: 14px; font-weight: 500; }
    nav .links a:hover { color: #fff; }
    .container { max-width: 1100px; margin: 0 auto; padding: 36px 24px; }
    .welcome { margin-bottom: 32px; }
    .welcome h2 { font-size: 26px; color: #1f2937; font-weight: 700; }
    .welcome p { color: #6b7280; font-size: 14px; margin-top: 4px; }
    .stats { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-bottom: 36px; }
    .stat-card { background: #fff; border-radius: 14px; padding: 24px; box-shadow: 0 2px 12px rgba(0,0,0,0.07); text-align: center; }
    .stat-card .icon { font-size: 32px; margin-bottom: 10px; }
    .stat-card .value { font-size: 36px; font-weight: 800; color: #1e1b4b; }
    .stat-card .label { font-size: 13px; color: #6b7280; margin-top: 4px; }
    .actions { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
    .action-card { background: #fff; border-radius: 14px; padding: 28px; box-shadow: 0 2px 12px rgba(0,0,0,0.07); text-decoration: none; display: block; transition: transform 0.15s; }
    .action-card:hover { transform: translateY(-3px); box-shadow: 0 6px 24px rgba(30,27,75,0.12); }
    .action-card .icon { font-size: 34px; margin-bottom: 12px; }
    .action-card h3 { font-size: 17px; color: #1f2937; font-weight: 700; margin-bottom: 6px; }
    .action-card p { font-size: 13px; color: #6b7280; }
  </style>
</head>
<body>
  <nav>
    <a class="brand" href="/owner/dashboard">🏠 RentEase <span style="font-size:12px;opacity:0.7;margin-left:4px;">Owner</span></a>
    <div class="links">
      <a href="/owner/properties">Properties</a>
      <a href="/owner/bookings">Bookings</a>
      <a href="/owner/add-property">+ Add</a>
      <a href="/owner/profile">Profile</a>
      <a href="/logout">Logout</a>
    </div>
  </nav>
  <div class="container">
    <div class="welcome">
      <h2>Welcome, <%= user.fullname %>! 🏘️</h2>
      <p>Manage your properties and bookings from here.</p>
    </div>
    <div class="stats">
      <div class="stat-card">
        <div class="icon">🏠</div>
        <div class="value"><%= totalProperties %></div>
        <div class="label">Total Properties</div>
      </div>
      <div class="stat-card">
        <div class="icon">🔑</div>
        <div class="value"><%= activeBookings %></div>
        <div class="label">Active Bookings</div>
      </div>
      <div class="stat-card">
        <div class="icon">📋</div>
        <div class="value"><%= totalBookings %></div>
        <div class="label">Total Bookings</div>
      </div>
    </div>
    <div class="actions">
      <a class="action-card" href="/owner/properties">
        <div class="icon">🏠</div>
        <h3>My Properties</h3>
        <p>View, edit and manage all your listed properties.</p>
      </a>
      <a class="action-card" href="/owner/bookings">
        <div class="icon">📅</div>
        <h3>Bookings</h3>
        <p>Track all guest reservations on your properties.</p>
      </a>
      <a class="action-card" href="/owner/add-property">
        <div class="icon">➕</div>
        <h3>Add Property</h3>
        <p>List a new property and start receiving bookings.</p>
      </a>
    </div>
  </div>
</body>
</html>
